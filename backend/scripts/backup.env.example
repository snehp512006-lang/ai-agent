# Copy this file to: backend/scripts/backup.env
# Fill values for your environment.

# MySQL connection
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_agent21
MYSQL_USER=root
MYSQL_PASSWORD=change_me

# Backup destination (absolute path recommended)
BACKUP_DIR=C:\backup\ai_ops

# Retention policy (delete .sql files older than this)
RETENTION_DAYS=30

# Optional: executable names if not in PATH
MYSQLDUMP_BIN=mysqldump
MYSQL_BIN=mysql
